    "liveNow": false,
    "panels": [
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "id": 1,
        "title": "Total VMs",
        "type": "stat",
        "targets": [
          {
            "azureMonitor": {
              "queryType": "Azure Resource Graph",
              "azureResourceGraph": {
                "query": "Resources | where type == 'microsoft.compute/virtualmachines' | summarize count() by subscriptionId"
              }
            },
            "queryType": "Azure Resource Graph",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "id": 2,
        "title": "Avg CPU % (All selected VMs)",
        "type": "gauge",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "percent",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] }
          }
        },
        "targets": [
          {
            "azureMonitor": {
              "metricName": "Percentage CPU",
              "metricNamespace": "Microsoft.Compute/virtualMachines",
              "resourceGroup": "$resourcegroup",
              "resourceName": "$vm",
              "subscription": "$subscription",
              "timeGrain": "auto"
            },
            "queryType": "Azure Monitor",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "id": 3,
        "title": "Avg Logical Disk Used % (VM Insights)",
        "type": "gauge",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "percent",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
          }
        },
        "targets": [
          {
            "azureLogAnalytics": {
              "query": "Perf | where ObjectName == 'LogicalDisk' and CounterName == '% Used Space' | summarize AvgValue = avg(CounterValue) by Computer, InstanceName | summarize OverallAvg = avg(AvgValue)",
              "resource": "/subscriptions/$subscription/resourceGroups/$resourcegroup/providers/Microsoft.OperationalInsights/workspaces/$workspace"
            },
            "queryType": "Azure Log Analytics",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
        "id": 4,
        "title": "VM Availability / Heartbeat",
        "type": "state-timeline",
        "targets": [
          {
            "azureLogAnalytics": {
              "query": "Heartbeat | summarize LastHeartbeat = max(TimeGenerated) by Computer | extend Status = iff(datetime_diff('minute', now(), LastHeartbeat) < 5, 'Up', 'Down')",
              "resource": "/subscriptions/$subscription/resourceGroups/$resourcegroup/providers/Microsoft.OperationalInsights/workspaces/$workspace"
            },
            "queryType": "Azure Log Analytics",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
        "id": 5,
        "title": "CPU % Over Time (All / Top VMs)",
        "type": "timeseries",
        "targets": [
          {
            "azureMonitor": {
              "metricName": "Percentage CPU",
              "metricNamespace": "Microsoft.Compute/virtualMachines",
              "resourceGroup": "$resourcegroup",
              "resourceName": "$vm",
              "subscription": "$subscription"
            },
            "queryType": "Azure Monitor",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
        "id": 6,
        "title": "Logical Disk % Used (VM Insights)",
        "type": "timeseries",
        "targets": [
          {
            "azureLogAnalytics": {
              "query": "Perf | where ObjectName == 'LogicalDisk' and CounterName == '% Used Space' | summarize AvgUsed = avg(CounterValue) by bin(TimeGenerated, 5m), Computer, InstanceName",
              "resource": "/subscriptions/$subscription/resourceGroups/$resourcegroup/providers/Microsoft.OperationalInsights/workspaces/$workspace"
            },
            "queryType": "Azure Log Analytics",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "azuremonitor" },
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 },
        "id": 7,
        "title": "Network In + Out Total (Bytes)",
        "type": "timeseries",
        "targets": [
          { "azureMonitor": { "metricName": "Network In Total", "metricNamespace": "Microsoft.Compute/virtualMachines", "subscription": "$subscription", "resourceGroup": "$resourcegroup", "resourceName": "$vm" }, "refId": "A" },
          { "azureMonitor": { "metricName": "Network Out Total", "metricNamespace": "Microsoft.Compute/virtualMachines", "subscription": "$subscription", "resourceGroup": "$resourcegroup", "resourceName": "$vm" }, "refId": "B" }
        ]
      }
    ],
