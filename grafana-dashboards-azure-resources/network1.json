        "title": "Total Network Resources",
        "type": "stat",
        "targets": [
          {
            "azureMonitor": {
              "queryType": "Azure Resource Graph",
              "azureResourceGraph": {
                "query": "Resources | where type contains 'microsoft.network/' | summarize count() by type"
              }
            },
            "queryType": "Azure Resource Graph",
            "refId": "A"
