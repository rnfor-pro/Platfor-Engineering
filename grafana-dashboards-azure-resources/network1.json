        "targets": [
          {
            "azureMonitor": {
              "metricName": "ByteCount",
              "metricNamespace": "Microsoft.Network/publicIPAddresses",
              "resourceGroup": "$resourcegroup",
              "resourceName": "$resource",
              "subscription": "$subscription"
            },
            "queryType": "Azure Monitor",
            "refId": "A"
          }
        ]
      },
