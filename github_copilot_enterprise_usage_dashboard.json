  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "Dashboard Overview",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "## Copilot Usage Overview\nThis dashboard summarizes enterprise Copilot adoption and usage patterns over time. It focuses on licensed capacity, active-user trends, chat and agent adoption, request volume, and usage distribution by feature and IDE so leaders can understand how broadly Copilot is being used and where engagement is strongest.\n\n**Tip:** set the time range to at least **Last 60 days** if you want February and March on the same view. February will only appear if those daily records were actually imported into VictoriaMetrics.",
        "mode": "markdown"
      },
      "pluginVersion": "12.0.0"
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Enterprise Seat Total",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "targets": [
        {
          "expr": "github_copilot_enterprise_seat_total{enterprise=\"$enterprise\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "purple",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0"
    },
