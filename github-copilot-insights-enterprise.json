{
    "__inputs": [
      {
        "name": "DS_VICTORIAMETRICS",
        "label": "VictoriaMetrics",
        "description": "Prometheus-compatible datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "pluginName": "Prometheus"
      }
    ],
    "__requires": [
      { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.0.0" },
      { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
      { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
      { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
      { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
    ],
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": { "type": "grafana", "uid": "-- Grafana --" },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "description": "GitHub Copilot enterprise insights from VictoriaMetrics",
    "editable": true,
    "graphTooltip": 1,
    "id": null,
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Enterprise Seat Total",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_enterprise_seat_total{enterprise=\"$enterprise\"}", "instant": true, "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
          "overrides": []
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "value" }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Latest Enterprise DAU",
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "last_over_time(github_copilot_daily_active_users{enterprise=\"$enterprise\"}[30d])", "instant": true, "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
          "overrides": []
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "value" }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Latest Enterprise MAU",
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "last_over_time(github_copilot_monthly_active_users{enterprise=\"$enterprise\"}[30d])", "instant": true, "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
          "overrides": []
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "value" }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Seat Rows Returned",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_enterprise_seat_rows_returned{enterprise=\"$enterprise\"}", "instant": true, "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] } },
          "overrides": []
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "value" }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Enterprise Adoption Trend",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_daily_active_users{enterprise=\"$enterprise\"}", "legendFormat": "DAU", "refId": "A" },
          { "expr": "github_copilot_weekly_active_users{enterprise=\"$enterprise\"}", "legendFormat": "WAU", "refId": "B" },
          { "expr": "github_copilot_monthly_active_users{enterprise=\"$enterprise\"}", "legendFormat": "MAU", "refId": "C" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Enterprise Chat / Agent / CLI Adoption",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_monthly_active_chat_users{enterprise=\"$enterprise\"}", "legendFormat": "Chat users", "refId": "A" },
          { "expr": "github_copilot_monthly_active_agent_users{enterprise=\"$enterprise\"}", "legendFormat": "Agent users", "refId": "B" },
          { "expr": "github_copilot_daily_active_cli_users{enterprise=\"$enterprise\"}", "legendFormat": "CLI users", "refId": "C" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Code Generation vs Acceptance",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_code_generation_activity_count{enterprise=\"$enterprise\"}", "legendFormat": "Code generation", "refId": "A" },
          { "expr": "github_copilot_code_acceptance_activity_count{enterprise=\"$enterprise\"}", "legendFormat": "Code acceptance", "refId": "B" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Acceptance Rate",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "100 * github_copilot_code_acceptance_activity_count{enterprise=\"$enterprise\"} / clamp_min(github_copilot_code_generation_activity_count{enterprise=\"$enterprise\"}, 1)", "legendFormat": "Acceptance rate", "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "color": { "mode": "palette-classic" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 20 },
                { "color": "green", "value": 40 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } }
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Lines of Code Trend",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          { "expr": "github_copilot_loc_suggested_to_add_sum{enterprise=\"$enterprise\"}", "legendFormat": "Suggested to add", "refId": "A" },
          { "expr": "github_copilot_loc_added_sum{enterprise=\"$enterprise\"}", "legendFormat": "Added", "refId": "B" },
          { "expr": "github_copilot_loc_deleted_sum{enterprise=\"$enterprise\"}", "legendFormat": "Deleted", "refId": "C" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } }
      },
      {
        "id": 10,
        "type": "bargauge",
        "title": "Top Enterprise Users by LoC Added",
        "gridPos": { "h": 9, "w": 8, "x": 0, "y": 20 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          {
            "expr": "topk($topn, sum by (user_login) (sum_over_time(github_copilot_user_loc_added_sum{enterprise=\"$enterprise\"}[$__range])))",
            "instant": true,
            "legendFormat": "{{user_login}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "continuous-GrYlRd" } },
          "overrides": []
        },
        "options": { "displayMode": "gradient", "namePlacement": "left", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
      },
      {
        "id": 11,
        "type": "bargauge",
        "title": "Top Enterprise Users by Code Acceptances",
        "gridPos": { "h": 9, "w": 8, "x": 8, "y": 20 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          {
            "expr": "topk($topn, sum by (user_login) (sum_over_time(github_copilot_user_code_acceptance_activity_count{enterprise=\"$enterprise\"}[$__range])))",
            "instant": true,
            "legendFormat": "{{user_login}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "continuous-GrYlRd" } },
          "overrides": []
        },
        "options": { "displayMode": "gradient", "namePlacement": "left", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
      },
      {
        "id": 12,
        "type": "bargauge",
        "title": "Top IDEs by LoC Added",
        "gridPos": { "h": 9, "w": 8, "x": 16, "y": 20 },
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "targets": [
          {
            "expr": "topk($topn, sum by (ide) (sum_over_time(github_copilot_ide_loc_added_sum{enterprise=\"$enterprise\"}[$__range])))",
            "instant": true,
            "legendFormat": "{{ide}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "continuous-GrYlRd" } },
          "overrides": []
        },
        "options": { "displayMode": "gradient", "namePlacement": "left", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true }
      }
    ],
    "refresh": "1h",
    "schemaVersion": 39,
    "tags": ["github", "copilot", "enterprise", "victoriametrics"],
    "templating": {
      "list": [
        {
          "name": "enterprise",
          "type": "query",
          "label": "Enterprise",
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "query": { "query": "label_values(github_copilot_enterprise_seat_total, enterprise)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
          "definition": "label_values(github_copilot_enterprise_seat_total, enterprise)",
          "refresh": 1,
          "includeAll": false,
          "multi": false,
          "sort": 1,
          "current": {}
        },
        {
          "name": "topn",
          "type": "custom",
          "label": "Top N",
          "query": "5,10,15,20",
          "current": { "selected": true, "text": "10", "value": "10" },
          "options": [
            { "selected": false, "text": "5", "value": "5" },
            { "selected": true, "text": "10", "value": "10" },
            { "selected": false, "text": "15", "value": "15" },
            { "selected": false, "text": "20", "value": "20" }
          ]
        }
      ]
    },
    "time": { "from": "now-30d", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "GitHub Copilot Enterprise Insights",
    "uid": "github-copilot-enterprise-insights",
    "version": 1,
    "weekStart": ""
  }